{
  "manifest_version": 3,
  "name": "Type Human",
  "version": "1.0.0",
  "description": "Transform AI-generated text into natural human writing styles.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}